{% extends 'base.html.twig' %}

{% block title %}Transmisión: {{ lesson.title }} - Hello World! Party{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            background-color: #050608;
            background-image: radial-gradient(circle at center, #111a22 0%, #050608 100%);
            height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        footer, nav { display: none !important; }
        
        .story-container {
            max-width: 800px;
            width: 90%;
            border: 1px solid rgba(102, 252, 241, 0.3);
            border-radius: 15px;
            background: rgba(0,0,0,0.7);
            box-shadow: 0 0 30px rgba(102, 252, 241, 0.1);
            backdrop-filter: blur(10px);
            padding: 3rem;
            position: relative;
        }
        
        /* Efecto de scanlines retro */
        .story-container::after {
            content: " ";
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 2;
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
            border-radius: 15px;
        }

        .avatar-father {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid var(--gamer-primary);
            box-shadow: 0 0 20px var(--gamer-primary);
            margin-bottom: 2rem;
            background-color: #1a1a1a;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse-border 2s infinite alternate;
        }
        
        @keyframes pulse-border {
            0% { box-shadow: 0 0 10px var(--gamer-primary); }
            100% { box-shadow: 0 0 30px var(--gamer-primary), 0 0 10px var(--gamer-primary) inset; }
        }

        .typing-text {
            color: #fff;
            font-size: 1.3rem;
            line-height: 1.8;
            font-family: 'Courier New', Courier, monospace;
            text-shadow: 0 0 5px rgba(255,255,255,0.3);
            min-height: 150px;
        }
        
        .typing-text p { margin-bottom: 1.5rem; }

        .btn-terminal {
            background-color: var(--gamer-primary);
            color: #000;
            font-weight: bold;
            font-size: 1.2rem;
            padding: 1rem 3rem;
            border: none;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s;
            box-shadow: 0 0 15px var(--gamer-primary);
            opacity: 0;
            transform: translateY(20px);
            animation: fade-in-up 1s forwards;
            animation-delay: 2s; /* Aparecerá después de un rato */
        }
        
        .btn-terminal:hover {
            transform: scale(1.05) translateY(0);
            box-shadow: 0 0 30px var(--gamer-primary);
            color: #000;
        }
        
        @keyframes fade-in-up {
            to { opacity: 1; transform: translateY(0); }
        }
        
        .signal-lost {
            color: #ff5555;
            font-weight: bold;
            letter-spacing: 5px;
            text-transform: uppercase;
            margin-bottom: 1rem;
            animation: blink 1s infinite;
        }
        @keyframes blink { 50% { opacity: 0; } }
    </style>
{% endblock %}

{% block body %}
    <div class="story-container text-center">
        <div class="signal-lost mb-4" id="signalStatus">Conexión Establecida</div>
        
        <div class="d-flex flex-column align-items-center">
            <div class="avatar-father">
                <i class="bi bi-person-bounding-box text-light" style="font-size: 4rem;"></i>
            </div>
            <h3 class="text-white fw-bold mb-1">El Padre</h3>
            <p class="text-info mb-4">Ingeniero Jefe - Búnker 42</p>
        </div>

        <div class="typing-text text-start mx-auto" style="max-width: 600px;" id="loreBox">
            {# Mostramos el lore (historia) de la BD #}
            {{ lesson.lore|raw }}
        </div>
        
        <div class="mt-5">
            <a href="{{ path('app_lesson_play', {'id': lesson.id}) }}" class="btn btn-terminal text-decoration-none">
                <i class="bi bi-terminal me-2"></i> Acceder a la Terminal
            </a>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Efecto Typewriter para el lore
            const loreBox = document.getElementById('loreBox');
            const originalHTML = loreBox.innerHTML;
            
            // Un truco sencillo para hacer un fade in del texto en lugar de escribir letra a letra
            // porque escribir HTML (etiquetas strong, p) letra a letra rompe el formato.
            loreBox.style.opacity = 0;
            let opacity = 0;
            let interval = setInterval(() => {
                opacity += 0.02;
                loreBox.style.opacity = opacity;
                if (opacity >= 1) clearInterval(interval);
            }, 50);
            
            // Jugar un pequeño sonido de terminal si es posible (los navegadores lo bloquean sin interacción, pero podemos simular el ambiente visual)
        });
    </script>
{% endblock %}
