{% extends 'base.html.twig' %}

{% block title %}Transmisión: {{ lesson.title }} - Hello World! Party{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            background-color: #050608;
            background-image: radial-gradient(circle at center, #111a22 0%, #050608 100%);
            height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        footer, nav { display: none !important; }
        
        .story-container {
            max-width: 800px;
            width: 90%;
            border: 1px solid rgba(102, 252, 241, 0.3);
            border-radius: 15px;
            background: rgba(0,0,0,0.7);
            box-shadow: 0 0 30px rgba(102, 252, 241, 0.1);
            backdrop-filter: blur(10px);
            padding: 3rem;
            position: relative;
        }
        
        /* Efecto de scanlines retro */
        .story-container::after {
            content: " ";
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 2;
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
            border-radius: 15px;
        }

        .avatar-father {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid #66fcf1;
            box-shadow: 0 0 20px #66fcf1;
            margin-bottom: 2rem;
            background-color: #1a1a1a;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse-border 2s infinite alternate;
        }
        
        @keyframes pulse-border {
            0% { box-shadow: 0 0 10px #66fcf1; }
            100% { box-shadow: 0 0 30px #66fcf1, 0 0 10px #66fcf1 inset; }
        }

        .typing-text {
            color: #fff;
            font-size: 1.3rem;
            line-height: 1.8;
            font-family: 'Courier New', Courier, monospace;
            text-shadow: 0 0 5px rgba(255,255,255,0.3);
            min-height: 150px;
        }
        
        .typing-text p { margin-bottom: 1.5rem; }

        .btn-terminal {
            background-color: #66fcf1;
            color: #000;
            font-weight: bold;
            font-size: 1.2rem;
            padding: 1rem 3rem;
            border: none;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s;
            box-shadow: 0 0 15px #66fcf1;
            opacity: 0;
            transform: translateY(20px);
            animation: fade-in-up 1s forwards;
            animation-delay: 2s; /* Aparecerá después de un rato */
        }
        
        .btn-terminal:hover {
            transform: scale(1.05) translateY(0);
            box-shadow: 0 0 30px #66fcf1;
            color: #000;
        }
        
        @keyframes fade-in-up {
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Cursor parpadeante para el typewriter */
        .typing-cursor::after {
            content: "█";
            animation: blink-cursor 1s infinite;
            color: #66fcf1;
        }
        @keyframes blink-cursor { 50% { opacity: 0; } }
        
        .signal-lost {
            color: #ff5555;
            font-weight: bold;
            letter-spacing: 5px;
            text-transform: uppercase;
            margin-bottom: 1rem;
            animation: blink 1s infinite;
        }
        @keyframes blink { 50% { opacity: 0; } }
    </style>
{% endblock %}

{% block body %}
    <div class="story-container text-center mx-auto">
        <div class="signal-lost mb-4" id="signalStatus">Conexión Establecida</div>
        
        <div class="flex flex-col items-center">
            <div class="avatar-father">
                <i class="bi bi-person-bounding-box text-white text-6xl"></i>
            </div>
            <h3 class="text-white font-bold mb-1 text-2xl">El Padre</h3>
            <p class="text-[#66fcf1] mb-8">Ingeniero Jefe - Búnker 42</p>
        </div>

        <div class="typing-text text-left mx-auto typing-cursor max-w-[600px]" id="loreBox">
            {# El contenido se inyectará letra a letra con JS #}
        </div>
        
        <!-- Guardamos el texto original invisible para que JS lo lea -->
        <div id="hiddenLore" class="hidden">{{ lesson.lore|raw }}</div>
        
        <div class="mt-12">
            <a href="{{ path('app_lesson_play', {'id': lesson.id}) }}" class="btn-terminal inline-flex items-center no-underline" id="btnStart">
                <i class="bi bi-terminal mr-2"></i> Acceder a la Terminal
            </a>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loreBox = document.getElementById('loreBox');
            const hiddenLore = document.getElementById('hiddenLore').innerHTML.trim();
            const btnStart = document.getElementById('btnStart');
            
            // Ocultar botón inicialmente
            btnStart.style.animation = 'none';
            btnStart.style.opacity = 0;
            
            // --- Sintetizador de Audio Retro (Web Audio API) ---
            let audioCtx = null;
            function playBeep() {
                try {
                    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                    const oscillator = audioCtx.createOscillator();
                    const gainNode = audioCtx.createGain();
                    
                    oscillator.type = 'square';
                    oscillator.frequency.setValueAtTime(800 + Math.random() * 200, audioCtx.currentTime); 
                    
                    gainNode.gain.setValueAtTime(0.05, audioCtx.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
                    
                    oscillator.connect(gainNode);
                    gainNode.connect(audioCtx.destination);
                    
                    oscillator.start();
                    oscillator.stop(audioCtx.currentTime + 0.05);
                } catch(e) { }
            }

            // --- Efecto Typewriter Avanzado (Soporta HTML) ---
            let i = 0;
            let isTag = false;
            let currentText = '';
            
            function typeWriter() {
                if (i < hiddenLore.length) {
                    const char = hiddenLore.charAt(i);
                    currentText += char;
                    loreBox.innerHTML = currentText;
                    
                    if (char === '<') isTag = true;
                    if (char === '>') isTag = false;
                    
                    i++;
                    
                    if (isTag) {
                        typeWriter(); 
                    } else {
                        if (i % 3 === 0) playBeep();
                        setTimeout(typeWriter, Math.random() * 40 + 20);
                    }
                } else {
                    loreBox.classList.remove('typing-cursor');
                    btnStart.style.animation = 'fade-in-up 1s forwards';
                }
            }
            
            setTimeout(typeWriter, 500);
        });
    </script>
{% endblock %}
