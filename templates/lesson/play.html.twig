{% extends 'base.html.twig' %}

{% block title %}Jugando: {{ lesson.title }} - Hello World! Party{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body, html {
            height: 100%;
            margin: 0;
            overflow: hidden; 
            background-color: #0b0c10;
        }
        .game-container {
            display: flex;
            height: calc(100vh - 70px); 
            border-top: 1px solid rgba(102, 252, 241, 0.2);
        }
        
        /* Panel Izquierdo: Historia */
        .lore-panel {
            width: 35%;
            background: linear-gradient(180deg, #1f2833 0%, #0b0c10 100%);
            padding: 2rem;
            overflow-y: auto;
            border-right: 2px solid rgba(102, 252, 241, 0.3);
            display: flex;
            flex-direction: column;
        }
        .lore-header {
            border-bottom: 1px dashed #66fcf1;
            padding-bottom: 1rem;
            margin-bottom: 1.5rem;
        }
        .typewriter-text {
            color: #c5c6c7;
            font-size: 1.1rem;
            line-height: 1.6;
        }
        
        /* Panel Derecho: Editor y Consola */
        .code-panel {
            width: 65%;
            display: flex;
            flex-direction: column;
            background-color: #1e1e1e; 
        }
        .editor-container {
            height: 70%;
            position: relative;
        }
        #editor {
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            font-size: 16px;
        }
        
        /* Consola Inferior */
        .console-container {
            height: 30%;
            background-color: #000;
            border-top: 2px solid #333;
            display: flex;
            flex-direction: column;
        }
        .console-header {
            background-color: #1a1a1a;
            padding: 0.5rem 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #333;
        }
        .console-output {
            padding: 1rem;
            color: #fff;
            font-family: 'Courier New', Courier, monospace;
            overflow-y: auto;
            flex-grow: 1;
        }
        .console-log { color: #fff; margin-bottom: 5px; }
        .console-error { color: #ff5555; margin-bottom: 5px; }
        .console-success { color: #50fa7b; margin-bottom: 5px; font-weight: bold; }
        
        /* Efecto Glitch al fallar */
        @keyframes glitch-anim {
            0% { transform: translate(0) }
            20% { transform: translate(-3px, 3px) }
            40% { transform: translate(-3px, -3px) }
            60% { transform: translate(3px, 3px) }
            80% { transform: translate(3px, -3px) }
            100% { transform: translate(0) }
        }
        .glitch-active {
            animation: glitch-anim 0.3s;
            animation-iteration-count: 3;
            box-shadow: inset 0 0 50px rgba(255, 0, 0, 0.5) !important;
        }
        
        footer { display: none !important; }

        /* Custom Offcanvas & Modal transitions */
        #offcanvasPadre {
            transition: transform 0.3s ease-in-out;
            transform: translateX(-100%);
        }
        #offcanvasPadre.open {
            transform: translateX(0);
        }
        
        #victoryModal.open {
            display: flex;
        }

        /* Responsive Design: Apilar paneles en pantallas pequeñas y permitir scroll */
        @media (max-width: 768px) {
            body, html {
                overflow: auto;
                height: auto;
            }
            .game-container {
                flex-direction: column;
                height: auto;
                min-height: calc(100vh - 70px);
            }
            .lore-panel {
                width: 100%;
                height: auto;
                min-height: 40vh;
                border-right: none;
                border-bottom: 2px solid rgba(102, 252, 241, 0.3);
            }
            .code-panel {
                width: 100%;
                height: 80vh; /* Altura total para el bloque derecho en móvil */
            }
            .editor-container {
                min-height: 50vh;
                height: auto;
            }
            .console-container {
                min-height: 30vh;
                height: auto;
            }
            .lore-header h2 {
                font-size: 1.5rem;
            }
            .typewriter-text {
                font-size: 0.95rem;
            }
        }

        /* Ocultar menú táctil nativo de Ace Editor */
        .ace_mobile-menu, .ace_mobile-button {
            display: none !important;
        }
    </style>
{% endblock %}

{% block body %}
<div class="game-container w-full max-w-full !px-0 !mx-0">
    
    <!-- LORE PANEL (Izquierda) -->
    <div class="lore-panel h-full">
        <div class="mb-4 flex justify-between items-center">
            <a href="{{ path('app_home') }}" class="text-gray-400 hover:text-white transition-colors flex items-center text-sm"><i class="bi bi-arrow-left mr-2"></i> Abortar Misión</a>
            <button id="btnOpenNotebook" class="text-xs border border-yellow-500 text-yellow-500 hover:bg-yellow-500 hover:text-black transition-colors rounded-full px-3 py-1.5 flex items-center shadow-[0_0_5px_rgba(234,179,8,0.3)]">
                <i class="bi bi-journal-bookmark-fill mr-1"></i> Libreta del Padre
            </button>
        </div>
        
        <div class="lore-header">
            <span class="inline-block bg-transparent border border-[#66fcf1] text-[#66fcf1] mb-3 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider"><i class="bi bi-geo-alt mr-1"></i> Nivel en curso</span>
            <h2 class="text-3xl font-bold text-[#66fcf1]">{{ lesson.title }}</h2>
        </div>
        
        <div class="typewriter-text font-sans text-base">
            {# Mostramos el contenido técnico (Pistas de Froggy) #}
            {{ lesson.content|raw }}
        </div>
    </div>
    
    <!-- CODE PANEL (Derecha) -->
    <div class="code-panel h-full">
        
        <!-- Editor de Código -->
        <div class="editor-container">
            <div id="editor">{{ lesson.initialCode }}</div>
        </div>
        
        <!-- Consola -->
        <div class="console-container">
            <div class="console-header flex justify-between items-center py-2 px-4 bg-[#1a1a1a] border-b border-[#333]">
                <span class="text-gray-400 font-bold flex items-center text-sm"><i class="bi bi-terminal mr-2"></i>Terminal del Sistema</span>
                <button id="runCodeBtn" class="bg-transparent border border-[#66fcf1] text-[#66fcf1] hover:bg-[#66fcf1] hover:text-black transition-all rounded-full px-5 py-1.5 font-bold text-sm shadow-[0_0_10px_rgba(102,252,241,0.2)] hover:shadow-[0_0_20px_rgba(102,252,241,0.8)] flex items-center">
                    <i class="bi bi-play-fill mr-1 text-lg"></i> Ejecutar Código
                </button>
            </div>
            <div class="console-output" id="consoleOutput">
                <div class="text-gray-500 italic">Esperando órdenes...</div>
            </div>
        </div>
        
    </div>
    <div id="game-data" class="hidden"
         data-expected-output="{{ lesson.expectedOutput|escape('html_attr') }}"
         data-submit-url="{{ path('app_lesson_submit', {'id': lesson.id}) }}">
    </div>

</div>

<!-- Modal Victoria Custom -->
<div id="victoryModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[100] hidden items-center justify-center">
    <div class="bg-[#1f2833] border border-[#66fcf1] rounded-2xl p-10 text-center max-w-md w-full shadow-[0_0_40px_rgba(102,252,241,0.3)] transform transition-all scale-100">
        <i id="victoryIcon" class="bi bi-trophy-fill text-6xl text-yellow-400 block mb-6 drop-shadow-[0_0_15px_rgba(250,204,21,0.6)]"></i>
        <h2 id="victoryTitle" class="text-3xl font-bold text-white mb-4">¡Misión Cumplida!</h2>
        <p id="victorySubtitle" class="text-gray-400 mb-6 text-lg">Has restaurado la terminal con éxito.</p>
        
        <div class="inline-block px-6 py-3 rounded-full border-2 border-yellow-400 text-yellow-400 font-bold text-2xl mb-8 bg-yellow-400/10 shadow-[0_0_15px_rgba(250,204,21,0.2)]">
            + <span id="xpGained">50</span> XP
        </div>
        
        <div class="mt-2">
            <a href="{{ path('app_home') }}" class="block w-full py-4 rounded-full bg-[#66fcf1] text-black font-bold uppercase tracking-wider hover:bg-white transition-colors shadow-[0_0_15px_rgba(102,252,241,0.5)]">
                Continuar Viaje <i class="bi bi-arrow-right ml-2"></i>
            </a>
        </div>
    </div>
</div>

<!-- Offcanvas: Apuntes del Padre Custom -->
<div id="offcanvasPadre" class="fixed inset-y-0 left-0 w-80 bg-[#0b0c10] border-r border-[#66fcf1] shadow-[5px_0_25px_rgba(102,252,241,0.15)] z-[90] flex flex-col">
    <div class="p-5 border-b border-[#45a29e]/50 flex justify-between items-center bg-[#1f2833]">
        <h5 class="font-bold text-white text-lg flex items-center"><i class="bi bi-journal-code text-yellow-500 mr-3"></i>Manual de Supervivencia</h5>
        <button id="btnCloseNotebook" class="text-gray-400 hover:text-white transition-colors text-2xl">&times;</button>
    </div>
    
    <div class="p-6 overflow-y-auto flex-grow font-mono text-sm">
        <p class="text-gray-400 mb-8 italic">"Hijo, si estás leyendo esto, es que te has atascado o es tu primer día frente a un teclado de verdad. La programación no es magia, es darle instrucciones extremadamente precisas a una máquina muy tonta. Aquí tienes mis viejos apuntes de supervivencia. Úsalos sabiamente." - El Padre</p>
        
        <div class="mb-8">
            <h6 class="text-[#66fcf1] font-bold border-b border-[#66fcf1]/30 pb-2 mb-3 uppercase tracking-wider text-xs">1. Hablar con la Máquina (Imprimir)</h6>
            <p class="text-gray-400 text-xs mb-2">La máquina es ciega y muda por defecto. Si quieres que te diga algo por la Terminal del Sistema, tienes que usar <code>console.log()</code>.</p>
            <ul class="text-gray-500 text-xs mb-2 list-disc pl-4">
                <li>Si quieres imprimir texto literal, <strong>debes usar comillas</strong> <code>" "</code> o <code>' '</code>.</li>
                <li>Si quieres imprimir el valor de una variable o un número, <strong>no uses comillas</strong>.</li>
            </ul>
            <code class="text-gray-300 block bg-black/50 p-2 rounded border border-gray-800 mb-1">console.log("Hola Búnker"); // Imprime: Hola Búnker</code>
            <code class="text-gray-300 block bg-black/50 p-2 rounded border border-gray-800">console.log(42); // Imprime el número: 42</code>
        </div>
        
        <div class="mb-8">
            <h6 class="text-[#66fcf1] font-bold border-b border-[#66fcf1]/30 pb-2 mb-3 uppercase tracking-wider text-xs">2. Cajas de Almacenamiento (Variables)</h6>
            <p class="text-gray-400 text-xs mb-2">Imagina las variables como cajas con una etiqueta donde guardamos información para usarla después.</p>
            <ul class="text-gray-500 text-xs mb-2 list-disc pl-4">
                <li><code>let</code>: Usa esto para crear una caja cuyo contenido <strong>puede cambiar</strong> en el futuro.</li>
                <li><code>const</code>: Usa esto para crear una caja sellada. Su contenido <strong>nunca puede cambiar</strong>.</li>
            </ul>
            <p class="text-[#ff5555] text-xs mb-2 font-bold"><i class="bi bi-exclamation-triangle"></i> IMPORTANTE: Nunca uses la palabra antigua 'var', provoca fugas de memoria en el reactor.</p>
            <code class="text-gray-300 block bg-black/50 p-2 rounded border border-gray-800 mb-1">let sobrevivientes = 15; // Podemos sumar más luego</code>
            <code class="text-gray-300 block bg-black/50 p-2 rounded border border-gray-800">const NIVEL_MAXIMO = 100; // Esto es fijo</code>
        </div>

        <div class="mb-8">
            <h6 class="text-[#66fcf1] font-bold border-b border-[#66fcf1]/30 pb-2 mb-3 uppercase tracking-wider text-xs">3. Matemáticas Básicas</h6>
            <p class="text-gray-400 text-xs mb-2">Puedes usar la terminal como una calculadora gigante para recalibrar los sistemas usando operadores: <code>+</code> (suma), <code>-</code> (resta), <code>*</code> (multiplicación), <code>/</code> (división).</p>
            <code class="text-gray-300 block bg-black/50 p-3 rounded border border-gray-800 whitespace-pre">let energiaBase = 20;
let multiplicador = 2;
let total = energiaBase * multiplicador; 
console.log(total); // Imprime: 40</code>
        </div>
        
        <div class="mb-8">
            <h6 class="text-[#66fcf1] font-bold border-b border-[#66fcf1]/30 pb-2 mb-3 uppercase tracking-wider text-xs">4. Tomar Decisiones (Condicionales)</h6>
            <p class="text-gray-400 text-xs mb-2">Sirven para bifurcar el camino. <strong>"SI pasa esto, haz esto; SINO, haz lo otro".</strong></p>
            <p class="text-gray-500 text-xs mb-2">Comparamos usando: <code>===</code> (igual a), <code>!==</code> (distinto de), <code>&gt;</code> (mayor que), <code>&lt;</code> (menor que).</p>
            <code class="text-gray-300 block bg-black/50 p-3 rounded border border-gray-800 whitespace-pre">let temperatura = 80;

if (temperatura > 50) {
  // Entra aquí si es verdadero
  console.log("¡Peligro de sobrecalentamiento!");
} else {
  // Entra aquí si es falso
  console.log("Sistemas estables");
}</code>
        </div>
        
        <div class="mb-8">
            <h6 class="text-[#66fcf1] font-bold border-b border-[#66fcf1]/30 pb-2 mb-3 uppercase tracking-wider text-xs">5. Automatizar Tareas (Bucles FOR)</h6>
            <p class="text-gray-400 text-xs mb-2">Los humanos nos cansamos de repetir cosas, las máquinas no. Si tienes que reiniciar 5 generadores, no escribas la instrucción 5 veces, usa un bucle <code>for</code>.</p>
            <p class="text-gray-500 text-xs mb-2">El bucle tiene 3 partes: <strong>(1)</strong> Dónde empezamos, <strong>(2)</strong> Cuándo nos detenemos, <strong>(3)</strong> De cuánto en cuánto avanzamos.</p>
            <code class="text-gray-300 block bg-black/50 p-3 rounded border border-gray-800 whitespace-pre">// (1) Empezamos en i = 1
// (2) Repetimos MIENTRAS i sea menor o igual a 3
// (3) En cada vuelta sumamos 1 a i (i++)
for (let i = 1; i <= 3; i++) {
  console.log("Reiniciando generador " + i);
}</code>
        </div>
    </div>
</div>

<!-- Modal Overlay -->
<div id="offcanvasOverlay" class="fixed inset-0 bg-black/50 z-[80] hidden backdrop-blur-sm transition-opacity opacity-0"></div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <!-- Cargar Ace Editor vía CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.4.12/ace.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.4.12/theme-dracula.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.4.12/mode-javascript.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // --- UI Setup (Modals y Offcanvas) ---
            const btnOpenNotebook = document.getElementById('btnOpenNotebook');
            const btnCloseNotebook = document.getElementById('btnCloseNotebook');
            const offcanvasPadre = document.getElementById('offcanvasPadre');
            const offcanvasOverlay = document.getElementById('offcanvasOverlay');
            
            function openNotebook() {
                offcanvasOverlay.classList.remove('hidden');
                setTimeout(() => offcanvasOverlay.classList.remove('opacity-0'), 10);
                offcanvasPadre.classList.add('open');
            }
            
            function closeNotebook() {
                offcanvasPadre.classList.remove('open');
                offcanvasOverlay.classList.add('opacity-0');
                setTimeout(() => offcanvasOverlay.classList.add('hidden'), 300);
            }
            
            btnOpenNotebook.addEventListener('click', openNotebook);
            btnCloseNotebook.addEventListener('click', closeNotebook);
            offcanvasOverlay.addEventListener('click', closeNotebook);


            // 1. Inicializar Ace Editor
            var editor = ace.edit("editor");
            editor.setTheme("ace/theme/dracula");
            editor.session.setMode("ace/mode/javascript");
            editor.setOptions({
                fontSize: "16px",
                showPrintMargin: false,
                wrap: true,
            });

            // 2. Motor de Evaluación y Consola
            const consoleOutput = document.getElementById('consoleOutput');
            const runBtn = document.getElementById('runCodeBtn');
            const gameData = document.getElementById('game-data');
            const expectedOutput = gameData.dataset.expectedOutput;
            const submitUrl = gameData.dataset.submitUrl;

            // Función para añadir mensajes a nuestra falsa consola HTML
            function printToConsole(message, type = 'log') {
                const div = document.createElement('div');
                div.className = `console-${type}`;
                // Convertimos objetos a string si es necesario
                if (typeof message === 'object') {
                    div.textContent = JSON.stringify(message);
                } else {
                    div.textContent = message;
                }
                consoleOutput.appendChild(div);
                // Hacer scroll abajo
                consoleOutput.scrollTop = consoleOutput.scrollHeight;
                return div.textContent;
            }

            // --- Sistema de Asistencia Activa (Inactividad) ---
            let inactivityTimer;
            const INACTIVITY_TIME = 45000; 
            
            function resetInactivityTimer() {
                clearTimeout(inactivityTimer);
                inactivityTimer = setTimeout(() => {
                    printToConsole('El Padre dice: [Transmisión entrante] ¿Sigues ahí, hijo? Recuerda revisar el manual de supervivencia a la izquierda si te atascas...', 'log');
                }, INACTIVITY_TIME);
            }
            
            editor.getSession().on('change', function() {
                resetInactivityTimer();
            });
            resetInactivityTimer();

            // --- Sistema de Pistas por Intentos Fallidos ---
            let failedAttempts = 0;

            runBtn.addEventListener('click', function() {
                consoleOutput.innerHTML = '';
                const code = editor.getValue();
                
                resetInactivityTimer();

                // --- Análisis de Código Estático (Ayuda Inteligente) ---
                let staticErrors = false;
                
                if (/\bvar\s+/.test(code)) {
                    printToConsole('El Padre dice: ¡Cuidado soldado! En este búnker usamos tecnología moderna. Sustituye esos "var" por "let" o "const" para evitar fugas de memoria en el reactor.', 'error');
                    staticErrors = true;
                }
                
                if (staticErrors) {
                    printToConsole('--- EJECUCIÓN ABORTADA POR PROTOCOLO ---', 'error');
                    return;
                }
                
                let userOutput = [];

                // Secuestrar console.log
                const originalLog = console.log;
                console.log = function(...args) {
                    const msg = args.join(' ');
                    printToConsole(msg, 'log');
                    userOutput.push(msg);
                    originalLog.apply(console, args);
                };
                
                // Secuestrar console.error
                const originalError = console.error;
                console.error = function(...args) {
                    const msg = args.join(' ');
                    printToConsole(msg, 'error');
                    originalError.apply(console, args);
                };

                try {
                    const executeCode = new Function(code);
                    executeCode();
                    
                    const finalOutputString = userOutput.join('\n').trim();
                    if (finalOutputString === expectedOutput.trim()) {
                        printToConsole('--- VALIDACIÓN EXITOSA ---', 'success');
                        triggerVictory(code);
                    } else {
                        failedAttempts++;
                        printToConsole('--- VALIDACIÓN FALLIDA ---', 'error');
                        printToConsole(`Se esperaba: "${expectedOutput}"`, 'error');
                        printToConsole(`Se recibió: "${finalOutputString}"`, 'error');
                        
                        if (failedAttempts >= 3) {
                            document.querySelector('.game-container').classList.add('glitch-active');
                            setTimeout(() => document.querySelector('.game-container').classList.remove('glitch-active'), 1000);
                            printToConsole('El Padre dice: [Alerta Táctica] Hijo, llevas varios intentos. Verifica detenidamente las mayúsculas, espacios y puntuación en lo que estás imprimiendo. ¡No te rindas!', 'log');
                        } else {
                            printToConsole('El Padre dice: ¡Revisa tu código, soldado! Algo no encaja.', 'log');
                        }
                    }
                } catch (e) {
                    failedAttempts++;
                    printToConsole(e.toString(), 'error');
                    
                    if (failedAttempts >= 3) {
                        document.querySelector('.game-container').classList.add('glitch-active');
                        setTimeout(() => document.querySelector('.game-container').classList.remove('glitch-active'), 1000);
                        printToConsole('El Padre dice: [Alerta Táctica] Demasiados fallos de sintaxis. ¿Seguro que has cerrado todas las llaves {}, paréntesis () y comillas ""? Revisa línea por línea.', 'log');
                    } else {
                        printToConsole('El Padre dice: Tienes un error de sintaxis grave. El Búnker no compila.', 'log');
                    }
                } finally {
                    console.log = originalLog;
                    console.error = originalError;
                }
            });

            function triggerVictory(codeSubmitted) {
                runBtn.disabled = true;
                runBtn.innerHTML = 'Guardando...';

                fetch(submitUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        code: codeSubmitted,
                        success: true,
                        failedAttempts: failedAttempts
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        // Lógica de Medalla de Oro (Código Perfecto)
                        if (data.xp_earned == 75) {
                            document.getElementById('victoryIcon').className = "bi bi-star-fill text-6xl block mb-6";
                            document.getElementById('victoryIcon').style.color = "#ffdf00";
                            document.getElementById('victoryIcon').style.filter = "drop-shadow(0 0 25px #ffdf00)";
                            document.getElementById('victoryTitle').innerText = "¡Código Perfecto!";
                            document.getElementById('victoryTitle').style.color = "#ffdf00";
                            document.getElementById('victorySubtitle').innerText = "Resolución brillante al primer intento. Bonificación de excelencia otorgada.";
                        }
                        
                        document.getElementById('xpGained').innerText = data.xp_earned;
                        document.getElementById('victoryModal').classList.add('open');
                    }
                })
                .catch(error => {
                    console.error('Error guardando progreso:', error);
                    printToConsole('Error de red guardando tu progreso.', 'error');
                    runBtn.disabled = false;
                    runBtn.innerHTML = '<i class="bi bi-play-fill mr-1"></i> Ejecutar Código';
                });
            }
        });
    </script>
{% endblock %}
