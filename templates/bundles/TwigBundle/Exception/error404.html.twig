{% extends 'base.html.twig' %}

{% block title %}Error 404 - Sector no encontrado{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[70vh] px-4">
    <div class="bg-[#1f2833] border border-red-500/50 rounded-2xl p-8 sm:p-12 text-center shadow-[0_0_30px_rgba(239,68,68,0.2)] max-w-2xl w-full relative overflow-hidden">
        
        <!-- Efecto de escaneo de fondo -->
        <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(239,68,68,0.05)_50%)] bg-[length:100%_4px] pointer-events-none"></div>

        <div class="relative z-10">
            <div class="inline-flex items-center justify-center w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-red-900/30 border border-red-500 mb-6 shadow-[0_0_20px_rgba(239,68,68,0.4)]">
                <i class="bi bi-exclamation-triangle-fill text-4xl sm:text-5xl text-red-500 animate-pulse"></i>
            </div>
            
            <h1 class="text-6xl sm:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-b from-red-400 to-red-700 mb-2 drop-shadow-[0_0_10px_rgba(239,68,68,0.8)]">404</h1>
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6 uppercase tracking-widest border-b border-red-500/30 pb-4">Sector no encontrado</h2>
            
            <p class="text-gray-400 text-base sm:text-lg mb-8 leading-relaxed">
                <span class="text-red-400 font-mono">> ERROR DEL SISTEMA:</span> La terminal a la que intentas acceder ha colapsado o está fuera de tu nivel de autorización.<br><br>
                Vuelve al refugio central antes de que los sistemas de soporte vital se queden sin energía.
            </p>
            
            <div class="flex justify-center">
                <a href="{{ path('app_home') }}" class="bg-transparent border-2 border-[#66fcf1] text-[#66fcf1] hover:bg-[#66fcf1] hover:text-black transition-all duration-300 px-6 sm:px-10 py-3 rounded-full font-bold uppercase tracking-widest text-sm sm:text-base flex items-center shadow-[0_0_15px_rgba(102,252,241,0.3)] hover:shadow-[0_0_25px_rgba(102,252,241,0.6)]">
                    <i class="bi bi-house-door-fill mr-2 sm:mr-3 text-lg sm:text-xl"></i>
                    Volver al Refugio
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
