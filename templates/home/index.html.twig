{% extends 'base.html.twig' %}

{% block title %}Inicio - Hello World! Party{% endblock %}

{% block body %}
<div>

    {% if app.user %}
        {# Vista para usuario logueado: Dashboard Gamer #}
        <div class="flex flex-col md:flex-row justify-between md:items-center mb-12 bg-[#0b0c10] p-6 rounded-2xl border border-[#45a29e]/30 shadow-[0_0_15px_rgba(69,162,158,0.1)]">
            <div class="flex items-center mb-6 md:mb-0">
                {% set avatarType = app.user.avatar and 'bottts' in app.user.avatar ? 'bottts' : 'avataaars' %}
                <img src="https://api.dicebear.com/7.x/{{ avatarType }}/svg?seed={{ app.user.avatar ?: app.user.email }}" alt="Avatar" class="w-20 h-20 rounded-full mr-6 border-2 border-[#66fcf1] p-1 shadow-[0_0_10px_rgba(102,252,241,0.5)] bg-[#1f2833]">
                <div>
                    <h1 class="text-2xl font-bold text-white mb-2 flex items-center">
                        Jugador: <span class="text-[#66fcf1] mx-2">{{ app.user.username ?: app.user.email | split('@')[0] }}</span>
                        <a href="{{ path('app_profile') }}" class="text-xs bg-[#1f2833] border border-[#45a29e] hover:bg-[#45a29e] text-white px-3 py-1 rounded-full transition-colors"><i class="bi bi-pencil-fill"></i></a>
                    </h1>
                    <p class="text-gray-400 mb-0 flex items-center"><i class="bi bi-shield-check mr-2 text-[#45a29e]"></i> Rango: {{ rankName ?? 'Aprendiz del Búnker' }}</p>
                </div>
            </div>
            <div class="text-left md:text-right">
                <div class="flex justify-start md:justify-end items-center mb-3">
                    <span class="text-white mr-3 font-bold">Nivel de Autorización</span>
                    <span class="bg-transparent border border-[#66fcf1] text-[#66fcf1] px-3 py-1 rounded-full text-sm font-bold shadow-[0_0_8px_rgba(102,252,241,0.3)]">{{ app.user.xp }} XP</span>
                </div>
                <div class="bg-[#0b0c10] h-3 rounded-full w-48 overflow-hidden border border-[#45a29e]/50 mb-4 ml-0 md:ml-auto" title="Progreso Total: {{ completedLessons|length }} / 9 niveles">
                    <div class="bg-[#66fcf1] h-full shadow-[0_0_10px_#66fcf1]" style="width: {{ (completedLessons|length / 9) * 100 }}%;"></div>
                </div>
                {% if is_granted('ROLE_ADMIN') %}
                <div class="flex justify-start md:justify-end">
                    <a href="{{ path('admin') }}" class="text-xs border border-yellow-500 text-yellow-500 hover:bg-yellow-500 hover:text-black transition-colors rounded-full px-4 py-1.5 shadow-sm"><i class="bi bi-gear-fill mr-1"></i> Ir al Backend (SuperAdmin)</a>
                </div>
                {% endif %}
            </div>
        </div>

        {% if courses is defined and courses|length > 0 %}
            <div class="flex justify-center">
                <div class="w-full lg:w-10/12">
                    <h3 class="mb-6 font-bold text-white text-xl flex items-center"><i class="bi bi-geo-alt text-[#66fcf1] mr-3"></i>Misiones Disponibles</h3>
                    
                    {% for course in courses %}
                        {# Lógica de bloqueo: Mundo 1 abierto. Mundo 2 requiere 3 lecciones. Mundo 3 requiere 6 lecciones. #}
                        {% set requiredLessons = loop.index0 * 3 %}
                        {% set isLocked = completedLessons|length < requiredLessons %}
                        
                        <div class="card-gamer mb-10 {% if isLocked %}opacity-75 grayscale pointer-events-none{% endif %}">
                            <div class="bg-gradient-to-r from-[#0b0c10] to-[#1f2833] text-white p-6 border-b border-[#45a29e]/50 flex justify-between items-center">
                                <div>
                                    <span class="inline-block bg-transparent border {% if isLocked %}border-red-500 text-red-500{% else %}border-gray-400 text-gray-300{% endif %} mb-3 px-4 py-1 rounded-full text-sm font-semibold tracking-wider">Mundo {{ loop.index }}</span>
                                    <h2 class="text-2xl font-bold flex items-center" style="color: {% if isLocked %}#ef4444{% else %}#66fcf1{% endif %};">
                                        {% if isLocked %}<i class="bi bi-lock-fill mr-3"></i>{% endif %}{{ course.title }}
                                    </h2>
                                </div>
                                <span class="text-sm px-3 py-1.5 rounded-lg border border-yellow-500 text-yellow-500 shadow-[0_0_10px_rgba(234,179,8,0.2)] flex items-center">
                                    <i class="bi bi-star-fill mr-2"></i> {{ course.difficulty }}
                                </span>
                            </div>
                            
                            <div class="p-0">
                                <div class="p-6 border-b border-[#45a29e]/20 bg-black/20">
                                    <p class="text-gray-300 text-lg flex items-start"><i class="bi bi-info-square mr-3 text-[#66fcf1] mt-1"></i>{{ course.description }}</p>
                                    {% if isLocked %}
                                        <div class="mt-4 bg-red-900/20 border border-red-500 text-red-400 p-4 rounded-lg flex items-center">
                                            <i class="bi bi-shield-lock-fill mr-3 text-xl"></i>
                                            <div>
                                                <strong class="block">Nivel de Autorización Insuficiente</strong>
                                                Necesitas reparar {{ requiredLessons }} terminales en total para acceder a este sector. Llevas {{ completedLessons|length }}.
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                                
                                <h5 class="px-6 pt-6 pb-2 text-gray-400 font-bold tracking-widest uppercase text-sm">Puntos de Control (Lecciones)</h5>
                                <ul class="list-none p-0 m-0">
                                    {% for lesson in course.lessons %}
                                        <li class="px-6 py-4 border-b border-[#45a29e]/10 flex items-center hover:bg-[#66fcf1]/5 transition-colors duration-200 {% if loop.last %}border-b-0{% endif %}">
                                            <div class="bg-[#66fcf1]/10 text-[#66fcf1] w-12 h-12 rounded-xl flex items-center justify-center mr-5 border border-[#66fcf1]/30 shadow-sm text-xl"><i class="bi bi-code-slash"></i></div>
                                            <div class="flex-grow">
                                                <h6 class="mb-1 text-white font-bold text-lg">{{ lesson.title }}</h6>
                                                <small class="text-gray-400 block mt-1">
                                                    {{ lesson.content|striptags }}
                                                </small>
                                            </div>
                                            <div>
                                                {% if lesson.id in completedLessons %}
                                                    <a href="{{ path('app_lesson_play', {'id': lesson.id}) }}" class="bg-green-600/20 text-green-400 border border-green-500 hover:bg-green-500 hover:text-white rounded-full px-4 py-2 text-sm font-bold transition-colors flex items-center" {% if isLocked %}tabindex="-1"{% endif %}><i class="bi bi-check-circle-fill mr-2"></i>Repasar</a>
                                                {% else %}
                                                    <a href="{{ path('app_lesson_story', {'id': lesson.id}) }}" class="btn-neon text-sm px-4 py-2 flex items-center" {% if isLocked %}tabindex="-1"{% endif %}><i class="bi bi-play-fill mr-1"></i>Jugar</a>
                                                {% endif %}
                                            </div>
                                        </li>
                                    {% else %}
                                        <li class="px-6 py-5 text-gray-500 italic">Aún no hay misiones disponibles. El Padre está preparándolas.</li>
                                    {% endfor %}
                                </ul>
                            </div>
                            <div class="p-6 border-t border-[#45a29e]/20 text-center bg-[#0b0c10]">
                                {% if course.lessons|length > 0 %}
                                    <a href="{{ path('app_lesson_story', {'id': course.lessons[0].id}) }}" class="{% if isLocked %}border border-red-500 text-red-500 px-8 py-3 rounded-full uppercase tracking-wider font-bold inline-block{% else %}bg-[#66fcf1] text-black px-10 py-3 rounded-full font-bold uppercase tracking-widest hover:bg-white transition-all duration-300 shadow-[0_0_15px_rgba(102,252,241,0.5)] hover:shadow-[0_0_25px_rgba(102,252,241,0.8)] hover:scale-105 inline-flex items-center{% endif %}" {% if isLocked %}tabindex="-1"{% endif %}>
                                        <i class="bi bi-play-fill mr-2 text-xl"></i> Iniciar Misión
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% else %}
            <div class="bg-[#1f2833] border border-dashed border-[#45a29e] rounded-xl p-10 text-center shadow-lg">
                <i class="bi bi-exclamation-triangle text-6xl text-[#66fcf1] block mb-6"></i>
                <h4 class="text-2xl font-bold text-white mb-2">Sistemas Inactivos</h4>
                <p class="text-gray-400">Tu padre aún no ha habilitado las terminales de mantenimiento. Mantente a la espera.</p>
            </div>
        {% endif %}

    {% else %}
        {# Vista para usuario NO logueado (Landing de bienvenida gamer) #}
        <div class="relative overflow-hidden bg-gradient-to-br from-[#1f2833] to-[#0b0c10] p-12 md:p-24 rounded-3xl mb-16 border border-[#66fcf1]/20 shadow-[0_10px_30px_rgba(0,0,0,0.5)]">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(102,252,241,0.05)_0%,transparent_60%)] animate-[pulse_4s_ease-in-out_infinite_alternate]"></div>
            
            <div class="relative z-10 text-center">
                <div class="inline-flex p-5 rounded-full bg-[#66fcf1]/10 border border-[#66fcf1] shadow-[0_0_20px_rgba(102,252,241,0.5)] mb-8">
                    <i class="bi bi-controller text-5xl text-[#66fcf1]"></i>
                </div>
                <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 drop-shadow-[0_0_20px_rgba(102,252,241,0.5)]">Hello World! <span class="text-[#66fcf1]">Party</span></h1>
                <p class="text-xl text-gray-300 mb-12 max-w-3xl mx-auto leading-relaxed">
                    Entra a la simulación. Domina la lógica de programación superando retos y subiendo de nivel. Tu aventura para convertirte en desarrollador empieza aquí.
                </p>
                
                <div class="flex justify-center">
                    <a href="{{ path('app_register') }}" class="bg-[#66fcf1] text-black px-12 py-4 rounded-full font-bold uppercase tracking-widest text-lg hover:bg-white transition-all duration-300 shadow-[0_0_20px_rgba(102,252,241,0.6)] hover:shadow-[0_0_30px_rgba(102,252,241,0.9)] hover:scale-105 flex items-center">
                        <i class="bi bi-lightning-charge-fill mr-3 text-xl"></i>Crear Personaje
                    </a>
                </div>
            </div>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 py-10">
            <div class="card-gamer p-8">
                <div class="mb-6">
                    <i class="bi bi-terminal-fill text-5xl text-[#66fcf1]"></i>
                </div>
                <h2 class="font-bold text-white text-2xl mb-4">Consola Interactiva</h2>
                <p class="text-gray-400 leading-relaxed">Escribe código real en tu navegador. Compila y ejecuta instantáneamente para derrotar los algoritmos.</p>
            </div>
            <div class="card-gamer p-8">
                <div class="mb-6">
                    <i class="bi bi-bar-chart-line-fill text-5xl text-[#66fcf1]"></i>
                </div>
                <h2 class="font-bold text-white text-2xl mb-4">Sube de Nivel</h2>
                <p class="text-gray-400 leading-relaxed">Gana puntos de experiencia (XP) completando misiones y desbloquea mundos más difíciles.</p>
            </div>
            <div class="card-gamer p-8">
                <div class="mb-6">
                    <i class="bi bi-trophy-fill text-5xl text-[#66fcf1]"></i>
                </div>
                <h2 class="font-bold text-white text-2xl mb-4">Logros Épicos</h2>
                <p class="text-gray-400 leading-relaxed">Consigue medallas raras por optimización de código y código limpio. Demuestra tu poder.</p>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
