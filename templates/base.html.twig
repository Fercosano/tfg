<!DOCTYPE html>
<html lang="es" class="dark">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Hello World! Party{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>👾</text></svg>">
        
        <!-- Tailwind CSS via CDN -->
        <script src="https://cdn.tailwindcss.com"></script>
        
        <!-- Script de configuración Tailwind para CDN -->
        <style type="text/tailwindcss">
            @layer base {
                :root {
                    --gamer-bg: #0b0c10;
                    --gamer-surface: #1f2833;
                    --gamer-primary: #66fcf1;
                    --gamer-secondary: #45a29e;
                    --gamer-text: #c5c6c7;
                    --neon-shadow: 0 0 10px rgba(102, 252, 241, 0.5);
                }
            }
            @layer components {
                .btn-neon {
                    @apply bg-transparent border border-[#66fcf1] text-[#66fcf1] px-6 py-2 rounded-lg font-bold tracking-wider uppercase transition-all duration-300;
                    box-shadow: 0 0 5px rgba(102, 252, 241, 0.2);
                }
                .btn-neon:hover {
                    @apply bg-[#66fcf1] text-black;
                    box-shadow: 0 0 15px rgba(102, 252, 241, 0.6);
                }
                .card-gamer {
                    @apply bg-[#1f2833] border border-[#45a29e] border-opacity-30 rounded-xl overflow-hidden shadow-lg transition-transform duration-300;
                }
                .card-gamer:hover {
                    @apply transform -translate-y-2 border-[#66fcf1];
                    box-shadow: 0 10px 20px rgba(0,0,0,0.5), 0 0 15px rgba(102, 252, 241, 0.2);
                }
                .input-gamer {
                    @apply w-full bg-[#0b0c10] border border-[#45a29e] text-[#c5c6c7] rounded-lg px-4 py-2 focus:outline-none focus:border-[#66fcf1] focus:ring-1 focus:ring-[#66fcf1] transition-colors;
                }
                .label-gamer {
                    @apply block text-[#66fcf1] text-sm font-bold mb-2 tracking-wide;
                }
            }
        </style>
        
        <!-- Bootstrap Icons (Permitido para iconos) -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        
        <!-- Hoja de Estilos Personalizada (Cumpliendo norma del tribunal) -->
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-[#0b0c10] text-[#c5c6c7] font-sans antialiased" data-turbo="false">
        
        <nav class="bg-[#0b0c10]/95 border-b border-[#45a29e] backdrop-blur-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <div class="flex-shrink-0">
                        <a href="{{ path('app_home') }}" class="text-[#66fcf1] font-extrabold tracking-widest uppercase flex items-center drop-shadow-[0_0_10px_rgba(102,252,241,0.5)]">
                            <i class="bi bi-controller text-2xl sm:mr-2"></i> <span class="hidden sm:inline">Hello World! Party</span>
                        </a>
                    </div>
                    
                    <div>
                        <div class="ml-2 sm:ml-4 flex items-center md:ml-6">
                            {% if not app.user %}
                                <a href="{{ path('app_login') }}" class="btn-neon text-sm sm:text-base px-4 py-1.5 sm:px-6 sm:py-2">Login</a>
                            {% else %}
                                <div class="flex items-center space-x-2 sm:space-x-3 bg-black/30 rounded-full px-3 py-1.5 sm:px-4 sm:py-2 border border-[#45a29e]/50">
                                    {% set navAvatarType = app.user.avatar and 'bottts' in app.user.avatar ? 'bottts' : 'avataaars' %}
                                    <img src="https://api.dicebear.com/7.x/{{ navAvatarType }}/svg?seed={{ app.user.avatar ?: app.user.email }}" alt="Avatar" class="h-6 w-6 sm:h-8 sm:w-8 rounded-full border border-[#66fcf1] bg-[#1f2833]">
                                    <span class="text-[#66fcf1] font-bold text-sm sm:text-base hidden sm:inline">{{ app.user.username ?: app.user.email | split('@')[0] }}</span>
                                    <span class="text-gray-500 mx-1 sm:mx-2 hidden sm:inline">|</span>
                                    <a href="{{ path('app_logout') }}" class="text-red-500 hover:text-red-400 font-bold transition-colors text-sm sm:text-base flex items-center">
                                        <i class="bi bi-box-arrow-right"></i> <span class="ml-1 hidden sm:inline">Salir</span>
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-20">
            {% block body %}{% endblock %}
        </main>
        
    </body>
</html>
