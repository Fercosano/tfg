<!DOCTYPE html>
<html lang="es" class="dark">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Hello World! Party{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>👾</text></svg>">
        
        <!-- Tailwind CSS via CDN -->
        <script src="https://cdn.tailwindcss.com"></script>
        
        <!-- Bootstrap Icons (Permitido para iconos) -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        
        <!-- Hoja de Estilos Personalizada (Cumpliendo norma del tribunal) -->
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-[#0b0c10] text-[#c5c6c7] font-sans antialiased" data-turbo="false">
        
        <nav class="bg-[#0b0c10]/95 border-b border-[#45a29e] backdrop-blur-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <div class="flex-shrink-0">
                        <a href="{{ path('app_home') }}" class="text-[#66fcf1] font-extrabold tracking-widest uppercase flex items-center drop-shadow-[0_0_10px_rgba(102,252,241,0.5)]">
                            <i class="bi bi-controller text-2xl mr-2"></i> Hello World! Party
                        </a>
                    </div>
                    
                    <div class="hidden md:block">
                        <div class="ml-4 flex items-center md:ml-6">
                            {% if not app.user %}
                                <a href="{{ path('app_login') }}" class="btn-neon">Login</a>
                            {% else %}
                                <div class="flex items-center space-x-3 bg-black/30 rounded-full px-4 py-2 border border-[#45a29e]/50">
                                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ app.user.email }}" alt="Avatar" class="h-8 w-8 rounded-full border border-[#66fcf1]">
                                    <span class="text-[#66fcf1] font-bold">{{ app.user.username ?: app.user.email | split('@')[0] }}</span>
                                    <span class="text-gray-500 mx-2">|</span>
                                    <a href="{{ path('app_logout') }}" class="text-red-500 hover:text-red-400 font-bold transition-colors">
                                        <i class="bi bi-box-arrow-right"></i> Salir
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-20">
            {% block body %}{% endblock %}
        </main>
        
    </body>
</html>
